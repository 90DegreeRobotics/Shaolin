# The Dojo Record is private. Never commit the practitioner's logs or config.
Dojo/data/

# Session video archive (the visual timeline) — large and private.
Dojo/media/

# Downloaded ML model assets (pose landmarker) — fetched on first use.
Dojo/models/

# Voice models (Whisper / Piper) — fetched on first use.
Dojo/voice/

# Public-domain wisdom corpus (raw Gutenberg dumps) — fetched on first use.
Wisdom/texts/

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/

# Local witness artifacts that may contain personal data
Dojo/witness/*.local.*

# Generated study artifacts (stroke-order renders, local exports, experiments).
# Promote specific files deliberately only after provenance/licensing is checked.
Dojo/artifacts/

# Local dev-tool configuration — not project content.
.claude/

# Forms: generated print artifacts and dated instances
Forms/print/*.pdf
Forms/print/weekly_review_week*.html

# Generated print PDFs/HTML (rebuild with tools/md2pdf.py)
Print/
